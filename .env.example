# Required: one API base URL OR multiple comma-separated base URLs (no trailing slash)
# Single:
VITE_API_BASE_URL=https://your-api.example.com
#
# If the portal is on another origin (e.g. Vercel) and the API is on *.ts.net, the API must
# allow CORS for your portal origin and include these headers in Access-Control-Allow-Headers:
# Content-Type, Authorization, X-Session-Id
# See backend-example/cors-for-portal.js for Express.
# Multi/failover (ex: dalawang tunnel o higit pa):
# VITE_API_BASE_URLS=https://api-a.devtunnels.ms,https://api-b.devtunnels.ms,https://api-c.devtunnels.ms
# Use URLs only — do not paste a full line like VITE_API_BASE_URL=https://... into VITE_API_BASE_URLS.

# Optional: API path prefix (e.g. /api). Leave empty if the API is at the root.
VITE_API_PREFIX=

# Local `npm run dev` only: set to `false` to call VITE_API_BASE_URL directly (needs CORS + Access-Control-Allow-Headers for X-Session-Id, Authorization, etc.).
# Default: when VITE_API_BASE_URL is remote, the app uses same-origin `/__portal_api` and Vite proxies to your API (avoids CORS in the browser).
# VITE_USE_DEV_PROXY=false

# Optional: exact session lookup path(s) for profile credential loading.
# Use this when your backend session endpoint is custom and avoids retrying multiple 404 paths.
# Single example:
# VITE_SESSION_LOOKUP_PATH=/security/session
# Multiple (comma-separated) example:
# VITE_SESSION_LOOKUP_PATHS=/security/session,/session,/api/security/session

# Optional: exact logout path if it is not POST /security/logout (e.g. /api/security/logout when using VITE_API_PREFIX).
# VITE_LOGOUT_PATH=/security/logout

# Optional: JSON map role_ID → portal segment after login (admin|marketing|finance|engineering) if /roles does not list every role.
# VITE_ROLE_ROUTE_MAP={"1":"admin","2":"marketing","3":"finance","4":"engineering"}

# Required for encrypted launch URLs on production builds (e.g. Vercel for this PORTAL app).
# Without it, the portal falls back to plain ?s_name=&acc_ID= on the opened URL.
# 32 bytes as standard base64, OR 64-character hex. Sub-apps must use the same key to decrypt.
# VITE_LAUNCH_AES_KEY=
#
# Local `npm run dev`: if unset, a dev-only key is derived (see LAUNCH_DEV_KEY_DERIVATION_STRING in appendSessionToUrl.ts).

# Optional: portal for executive titles (CEO, COO, …). General Manager uses /general-manager by default in app routing.
# VITE_EXECUTIVE_DEFAULT_ROUTE=admin

# Employee API: Sequelize requires Emp_AddressID and acc_ID on create.
# Use a real Address row ID from your DB when the app cannot create one via /addresses/...
VITE_DEFAULT_EMP_ADDRESS_ID=1

# Must match an existing account row linked to this employee (your employeeModel.acc_ID).
VITE_DEFAULT_ACC_ID=1
