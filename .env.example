# Required: one API base URL OR multiple comma-separated base URLs (no trailing slash)
# Single:
VITE_API_BASE_URL=https://your-api.example.com
# Multi/failover (ex: dalawang tunnel o higit pa):
# VITE_API_BASE_URLS=https://api-a.devtunnels.ms,https://api-b.devtunnels.ms,https://api-c.devtunnels.ms

# Optional: API path prefix (e.g. /api). Leave empty if the API is at the root.
VITE_API_PREFIX=

# Employee API: Sequelize requires Emp_AddressID and acc_ID on create.
# Use a real Address row ID from your DB when the app cannot create one via /addresses/...
VITE_DEFAULT_EMP_ADDRESS_ID=1

# Must match an existing account row linked to this employee (your employeeModel.acc_ID).
VITE_DEFAULT_ACC_ID=1
